<h1>Login</h1>
<p class="text-red-500"><%= Phoenix.Flash.get(@flash, :error) %></p>
<.form :let={f} for={@conn.params["session"] || %{}} action={~p"/sessions"} as={:session}>
  
  <div>
    <.input field={f[:username]} type="text" placeholder="Username" label="Username" />
  </div>
  <div>
    <.input field={f[:password]} type="text" placeholder="Password" label="Password" />
  </div>
  <div class="mt-4">
    <button type="submit" class="btn btn-primary">Log in</button>
  </div>
</.form>
